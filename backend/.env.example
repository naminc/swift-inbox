# ──────────────────────────────────────────────
# Swift Inbox — Backend Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in all values.
# Do NOT commit .env to version control.

# ── General ────────────────────────────────────

# Log level for pino logger (trace | debug | info | warn | error | fatal)
LOG_LEVEL='info'

# Application environment (development | production | test)
NODE_ENV='development'

# HTTP port the server listens on
PORT='9000'

# Allowed CORS origin. Set to your frontend URL.
# Only a single origin is supported; for multiple origins, deploy separate instances.
CORS_ORIGIN='http://localhost:5173'

# ── Database ───────────────────────────────────

# MySQL connection string
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL='mysql://root:password@localhost:3306/swift_inbox'

# ── Admin Authentication ───────────────────────

# Email address for the single admin account
ADMIN_EMAIL='admin@example.com'

# Password for the admin account — use a strong, unique password in production
ADMIN_PASSWORD='change_me_to_a_strong_admin_password'

# Secret key used to sign HMAC auth tokens — must be at least 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET='change_me_to_a_long_random_secret_at_least_32_chars'

# Name of the httpOnly cookie used for admin session
AUTH_COOKIE_NAME='swift_inbox_admin'

# How long admin auth tokens are valid (in seconds). Default: 86400 (24h)
AUTH_TOKEN_TTL_SECONDS='86400'

# ── Workers ────────────────────────────────────

# Interval in seconds between cleanup worker runs. Default: 600 (10 min)
CLEANUP_INTERVAL_SECONDS='600'

# ── Inbound Email (Cloudflare Worker) ──────────

# Shared secret between the Cloudflare email worker and this backend.
# Must match the INBOUND_SECRET env var in your Cloudflare worker.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
INBOUND_WEBHOOK_SECRET='change_me_to_a_long_random_secret_at_least_32_chars'
